{
  "name": "recruit-my-english",
  "version": "1.0.5",
  "description": "Recruit My English — simple desktop app",
  "main": "main.js",
  "scripts": {
    "test": "vitest run",
    "sync:app-backgrounds": "node scripts/sync-app-backgrounds-to-supabase.cjs",
    "setup:voice": "powershell -ExecutionPolicy Bypass -File scripts/setup-voice-stack.ps1 -WriteEnv",
    "setup:ffmpeg": "powershell -ExecutionPolicy Bypass -File scripts/setup-voice-stack.ps1 -FfmpegOnly -WriteEnv",
    "setup:voice-env": "powershell -ExecutionPolicy Bypass -File scripts/patch-voice-env.ps1",
    "start": "electron .",
    "dist": "node scripts/bake-supabase-public-env.cjs && electron-builder --win nsis --publish never",
    "dist:portable": "node scripts/bake-supabase-public-env.cjs && electron-builder --win portable --publish never",
    "dist:dir": "node scripts/bake-supabase-public-env.cjs && electron-builder --win --dir --publish never",
    "release": "node scripts/bake-supabase-public-env.cjs && electron-builder --win nsis --publish always",
    "release:win": "node scripts/bake-supabase-public-env.cjs && electron-builder --win nsis --publish always"
  },
  "author": "",
  "license": "MIT",
  "husky": {
    "hooks": {
      "pre-commit": ".githooks/pre-commit"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@supabase/supabase-js": "^2.105.1",
    "@xenova/transformers": "^2.17.2",
    "discord.js": "^14.26.4",
    "dotenv": "^16.6.1",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "jspdf": "^4.2.1",
    "koffi": "^2.16.2",
    "number-to-words": "1.2.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.recruitmyenglish.app",
    "productName": "Recruit My English",
    "directories": {
      "output": "dist"
    },
    "files": [
      "package.json",
      "*.js",
      "lib/**/*.js",
      "*.html",
      "assets/**/*",
      "node_modules/dotenv/**/*",
      "node_modules/@supabase/**/*",
      "node_modules/ws/**/*",
      "node_modules/tslib/**/*",
      "node_modules/jspdf/**/*",
      "node_modules/fflate/**/*",
      "node_modules/@babel/runtime/**/*",
      "node_modules/atob/**/*",
      "node_modules/btoa/**/*",
      "node_modules/koffi/**/*",
      "node_modules/@xenova/**/*",
      "node_modules/onnxruntime-node/**/*",
      "node_modules/ffmpeg-static/**/*",
      "lib/voice-agent.js",
      "lib/voice-agent/**/*.js",
      "lib/voice/**/*.js",
      "lib/voice-env-resolve.js",
      "lib/tts/cartesia.js",
      "lib/tts/index.js",
      "lib/tts/normalize.js",
      "lib/tts/chunk.js",
      "lib/log.js",
      "node_modules/number-to-words/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/semver/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "auto-update.js",
      "win-efficiency-mode.js"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "RME-17",
        "repo": "Teachers-Portal",
        "releaseType": "release"
      }
    ],
    "extraResources": [
      {
        "from": ".env.example",
        "to": ".env.example"
      },
      {
        "from": "supabase.public.env",
        "to": "supabase.public.env"
      },
      {
        "from": "tools/stt",
        "to": "tools/stt"
      },
      {
        "from": "tools/vad",
        "to": "tools/vad"
      },
      {
        "from": "tools/tts",
        "to": "tools/tts"
      },
      {
        "from": "scripts/setup-voice-gpu.ps1",
        "to": "setup-voice-gpu.ps1"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": true
    }
  }
}
